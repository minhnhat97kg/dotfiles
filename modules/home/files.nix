{ ... }:
{
  # SSH client — low-latency multiplexed connections
  programs.ssh = {
    enable = true;
    extraConfig = ''
      # Reuse connections — eliminates handshake on subsequent sessions
      ControlMaster auto
      ControlPath ~/.ssh/sockets/%r@%h-%p
      ControlPersist 600

      # Fast connection setup
      AddKeysToAgent yes
      ServerAliveInterval 30
      ServerAliveCountMax 3
      Compression no
    '';
  };

  home.file.".ssh/authorized_keys" = {
    text = ''
      ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIH1mPlgK5eEnwi65Pp5/6d40fc1VVNB5h+MW4zs939I1 nhat-buuuk
      ssh-rsa  nhath@Nhats-MacBook-Pro.local
      ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIO2l2A8T7RANMQMhXsLjxC73px574LJfa2nWkYouPSd6 minhnhat97kg
      ssh-rsa  nhath@Nathan-Macbook
      ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIKW6ArdpBefiw9CbO/7So0CpLmTSK0OlRh0YjB2oy71R Generated By Termius
    '';
  };

  programs.lazygit = {
    enable = true;
    enableZshIntegration = false; # Disable lg() function, use simple alias instead
  };

  programs.direnv.enable = true;

  home.file.".config/nvim/" = {
    source = ../../nvim;
    recursive = true;
    force = true;
  };
  home.file.".scripts/" = {
    source = ../../scripts;
    recursive = true;
    executable = true;
    force = true;
  };
}
